# SmartHR Nexus — Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (leave as-is for local development with Vite proxy)
VITE_API_URL=/api/v1

# ── Google Gemini AI (for ARIA Chat Assistant) ──────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# App config (optional)
VITE_APP_NAME=SmartHR Nexus
VITE_APP_VERSION=1.0.0
